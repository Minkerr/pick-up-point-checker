# User-Agent for Nominatim (required by their ToS)
NOMINATIM_USER_AGENT=pick-up-point-checker/1.0

# CORS origins for frontend (comma-separated)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Cookie из браузера для pvz-map.ozon.ru (истекает, периодически обновлять)
# Как получить: DevTools → Network → любой запрос creation-availability → Request Headers → Cookie
OZON_COOKIE=

# API-ключ Яндекс Карт JS (для фронтенда)
# Получить: https://developer.tech.yandex.ru/services/3
YANDEX_MAPS_API_KEY=
